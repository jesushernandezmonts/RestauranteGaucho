// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS ───────────────────────────────────────────
enum Role {
  MESERO
  CHEF
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  nombre       String
  usuario      String   @unique
  passwordHash String
  role         Role     @default(MESERO)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  ordenes  Orden[]
  pagos    Pago[]
  cortesCaja CorteCaja[]
  auditoriaCancelaciones AuditoriaCancelacion[]
}

// ─── MESAS ──────────────────────────────────────────────
enum MesaEstado {
  LIBRE
  OCUPADO
  CUENTA
}

model Mesa {
  id        Int        @id @default(autoincrement())
  numero    Int        @unique
  capacidad Int        @default(4)
  area      String     @default("Salón")
  estado    MesaEstado @default(LIBRE)
  updatedAt DateTime   @default(now()) @updatedAt
  ordenes   Orden[]
}

// ─── CATEGORÍAS ─────────────────────────────────────────
model Categoria {
  id     Int    @id @default(autoincrement())
  nombre String
  icono  String @default("🍽️")
  orden  Int    @default(0)

  platillos Platillo[]
}

// ─── PLATILLOS ──────────────────────────────────────────
model Platillo {
  id           Int     @id @default(autoincrement())
  categoriaId  Int
  nombre       String
  descripcion  String  @default("")
  precio       Float
  imagen       String  @default("")
  activo       Boolean @default(true)
  ingredientesDestacados String @default("")
  orden        Int     @default(0)
  createdAt    DateTime @default(now())

  categoria    Categoria        @relation(fields: [categoriaId], references: [id])
  receta       Receta[]
  detalleOrden DetalleOrden[]
}

// ─── INGREDIENTES ───────────────────────────────────────
model Ingrediente {
  id           Int    @id @default(autoincrement())
  nombre       String @unique
  unidad       String @default("pieza")
  stock        Float  @default(0)
  stockMinimo  Float  @default(10)
  costoSugerido Float @default(0)

  receta           Receta[]
  inventarioMov    InventarioMovimiento[]
}

// ─── RECETAS (relación platillo ↔ ingredientes) ─────────
model Receta {
  id            Int  @id @default(autoincrement())
  platilloId    Int
  ingredienteId Int
  cantidad      Float

  platillo    Platillo    @relation(fields: [platilloId], references: [id])
  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@unique([platilloId, ingredienteId])
}

// ─── ÓRDENES ────────────────────────────────────────────
enum OrdenEstado {
  ABIERTA
  EN_COCINA
  PREPARANDO
  LISTO
  SERVIDO
  CERRADA
  CANCELADA
}

model Orden {
  id        Int         @id @default(autoincrement())
  mesaId    Int
  meseroId  Int
  estado    OrdenEstado @default(ABIERTA)
  total     Float       @default(0)
  propina   Float       @default(0)
  tipoPropina String    @default("") // "cantidad" o "porcentaje"
  metodoPago String     @default("") // "efectivo" o "tarjeta"
  descuento Float       @default(0)
  tipoDescuento String  @default("") // "porcentaje", "monto" o "cortesia"
  motivoDescuento String @default("")
  cerradaPor Int?       // userId de quien cerró
  motivoCancelacion String? @default("")
  createdAt  DateTime   @default(now())
  closedAt   DateTime?

  mesa       Mesa           @relation(fields: [mesaId], references: [id])
  mesero     User           @relation(fields: [meseroId], references: [id])
  detalle    DetalleOrden[]
  pagos      Pago[]
  auditoriaCancelaciones AuditoriaCancelacion[]

  @@index([estado, createdAt])
  @@index([mesaId, estado])
  @@index([meseroId])
}

// ─── DETALLE DE ORDEN ───────────────────────────────────
model DetalleOrden {
  id         Int     @id @default(autoincrement())
  ordenId    Int
  platilloId Int
  cantidad   Int     @default(1)
  subtotal   Float
  cancelado  Boolean @default(false)
  motivoCancelacion String? @default("")

  orden     Orden      @relation(fields: [ordenId], references: [id])
  platillo  Platillo   @relation(fields: [platilloId], references: [id])
  extras    ExtraOrden[]
  opciones  OpcionOrden[]
  auditoriaCancelaciones AuditoriaCancelacion[]
}

// ─── EXTRAS DE UN PLATILLO EN LA ORDEN ──────────────────
model ExtraOrden {
  id           Int    @id @default(autoincrement())
  detalleOrdenId Int
  nombre       String
  precio       Float

  detalleOrden DetalleOrden @relation(fields: [detalleOrdenId], references: [id])
}

// ─── OPCIONES (quitar ingredientes / notas) ──────────────
enum OpcionTipo {
  QUITAR
  NOTA
}

model OpcionOrden {
  id           Int       @id @default(autoincrement())
  detalleOrdenId Int
  tipo         OpcionTipo
  valor        String

  detalleOrden DetalleOrden @relation(fields: [detalleOrdenId], references: [id])
}

// ─── PAGOS ──────────────────────────────────────────────
model Pago {
  id          Int      @id @default(autoincrement())
  ordenId     Int
  meseroId    Int
  metodo      String   // "efectivo" o "tarjeta"
  monto       Float
  propina     Float    @default(0)
  createdAt   DateTime @default(now())

  orden  Orden  @relation(fields: [ordenId], references: [id])
  mesero User   @relation(fields: [meseroId], references: [id])
}

// ─── MOVIMIENTOS DE INVENTARIO ─────────────────────────
enum MovimientoTipo {
  ENTRADA
  SALIDA
}

model InventarioMovimiento {
  id            Int            @id @default(autoincrement())
  ingredienteId Int
  tipo          MovimientoTipo
  cantidad      Float
  referencia    String         @default("")
  createdAt     DateTime       @default(now())

  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])
}

// ─── RESERVACIONES (futuro) ────────────────────────────
model Reservacion {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String   @default("")
  email     String   @default("")
  fecha     DateTime
  hora      String
  personas  Int      @default(2)
  notas     String   @default("")
  estado    String   @default("pendiente") // pendiente, confirmada, cancelada
  createdAt DateTime @default(now())
}

// ─── PUSH SUBSCRIPTIONS (Web Push) ────────────
model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    Int?     // ID del usuario que suscribió este dispositivo
  role      Role?    // MESERO o CHEF — para filtrar notificaciones
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// ─── CONFIGURACIÓN DE APARIENCIA ─────────────
model Configuracion {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String @default("")
}

// ─── PROMOCIONES ─────────────────────────────
model Promocion {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String   @default("")
  descuento   String   @default("")
  imagen      String   @default("")
  fechaInicio DateTime @default(now())
  fechaFin    DateTime?
  activo      Boolean  @default(true)
  destacado   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── CORTE DE CAJA (CORTE Z) ─────────────────
model CorteCaja {
  id                 Int      @id @default(autoincrement())
  usuarioId          Int
  fechaInicio        DateTime
  fechaFin           DateTime @default(now())
  montoInicial       Float    @default(0)
  ventasEfectivo     Float    @default(0)
  ventasTarjeta      Float    @default(0)
  totalVentas        Float    @default(0)
  totalPropinas      Float    @default(0)
  efectivoReal       Float    @default(0)
  diferencia         Float    @default(0)
  notas              String   @default("")
  createdAt          DateTime @default(now())

  usuario User @relation(fields: [usuarioId], references: [id])
}

// ─── BITÁCORA DE AUDITORÍA DE CANCELACIONES ──
model AuditoriaCancelacion {
  id             Int      @id @default(autoincrement())
  usuarioId      Int
  ordenId        Int
  detalleOrdenId Int?
  platilloNombre String   @default("")
  cantidad       Int      @default(1)
  montoPerdido   Float    @default(0)
  motivo         String
  createdAt      DateTime @default(now())

  usuario      User          @relation(fields: [usuarioId], references: [id])
  orden        Orden         @relation(fields: [ordenId], references: [id])
  detalleOrden DetalleOrden? @relation(fields: [detalleOrdenId], references: [id])
}

